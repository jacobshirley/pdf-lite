  },
  {
    "bbox": {
      "height": 13.75,
      "width": 367.36699999999996,
      "x": 183.96100000000004,
      "y": 292.1022,
    },
    "text": " forms may result in the cancellation of the Intermediary Link without notice.",
  },
  {
    "bbox": {
      "height": 16.25,
      "width": 29.418999999999983,
      "x": 199.0571,
      "y": 633.4489,
    },
    "text": "IN",
  },
  {
    "bbox": {
      "height": 12.5,
      "width": 521.2399999999993,
      "x": 36,
      "y": 178.2237,
    },
    "text": "The Revenue Commissioners collect taxes and duties and implement customs controls. Revenue requires customers ",
  },
  {
    "bbox": {
      "height": 12.5,
      "width": 476.85999999999956,
      "x": 36,
      "y": 166.2237,
    },
    "text": "to provide certain personal data for these purposes and certain other statutory functions as assigned by the ",
  },
  {
    "bbox": {
      "height": 12.5,
      "width": 497.4119999999996,
      "x": 36,
      "y": 154.2237,
    },
    "text": "Oireachtas. Your personal data may be exchanged with other Government Departments and agencies in certain ",
  },
  {
    "bbox": {
      "height": 12.5,
      "width": 508.8890000000001,
      "x": 36,
      "y": 142.2237,
    },
    "text": "circumstances where this is provided for by law. Full details of Revenue’s data protection policy setting out how we ",
  },
  {
    "bbox": {
      "height": 12.5,
      "width": 484.0399999999994,
      "x": 36,
      "y": 130.2237,
    },
    "text": "will use your personal data as well as information regarding your rights as a data subject are available on our ",
  },
  {
    "bbox": {
      "height": 12.5,
      "width": 36.08000000000004,
      "x": 519.6,
      "y": 130.2237,
    },
    "text": "Privacy",
  },
  {
    "bbox": {
      "height": 12.5,
      "width": 3.2799999999999727,
      "x": 555.19,
      "y": 130.2237,
    },
    "text": " ",
  },
  {
    "bbox": {
      "height": 12.5,
      "width": 39.42,
      "x": 36.010000000000105,
      "y": 118.22370000000001,
    },
    "text": "page on ",
  },
  {
    "bbox": {
      "height": 12.5,
      "width": 75.714,
      "x": 74.94000000000011,
      "y": 118.22370000000001,
    },
    "text": "www.revenue.ie",
  },
  {
    "bbox": {
      "height": 12.5,
      "width": 296.19000000000005,
      "x": 150.1540000000001,
      "y": 118.22370000000001,
    },
    "text": ". Details of this policy are also available in hard copy upon request.",
