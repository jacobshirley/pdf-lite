      {
        "h": 15,
        "text": "Part C – Registering for a payroll deductions program account (RP)",
        "w": 384.01,
        "x": 27,
        "y": 735.56,
      },
      {
        "h": 12.5,
        "text": "Fill in parts C1 and C2 if you need a payroll deductions program account.",
        "w": 323.42,
        "x": 27,
        "y": 715.75,
      },
      {
