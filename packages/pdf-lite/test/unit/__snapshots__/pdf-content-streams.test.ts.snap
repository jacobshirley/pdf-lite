      },
      {
        "h": 13.75,
        "text": "Part A4 – Major business activity",
        "w": 172.34,
        "x": 27,
        "y": 377.19,
      },
      {
        "h": 12.5,
        "text": "Describe your major business activity with as much detail as possible. Use at least a noun, a verb, and an adjective to ",
        "w": 523.5,
        "x": 27,
        "y": 356.22,
      },
      {
        "h": 12.5,
        "text": "describe your activity. Example: Residential construction – Installing hardwood flooring. ",
        "w": 388.43,
        "x": 27,
        "y": 344.22,
      },
      {
        "h": 12.5,
        "text": "Note:",
        "w": 26.05,
        "x": 27,
        "y": 315.22,
      },
      {
