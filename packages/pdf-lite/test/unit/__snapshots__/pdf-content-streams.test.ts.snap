  },
  {
    "bbox": {
      "height": 13.75,
      "width": 90.44200000000004,
      "x": 36,
      "y": 292.1022,
    },
    "text": "*Please note that ",
  },
  {
    "bbox": {
      "height": 13.75,
      "width": 58.619,
      "x": 125.89200000000002,
      "y": 292.1022,
    },
