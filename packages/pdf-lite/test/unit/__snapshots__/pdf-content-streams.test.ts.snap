      "x": 36,
      "y": 634.3308,
    },
    "text": "Intermediary Number",
  },
  {
    "bbox": {
      "height": 17.030300000000125,
      "width": 320.86230000000006,
      "x": 36,
      "y": 599.1587999999999,
    },
    "text": "I confirm that with effect from D    D      M    M       Y     Y    Y     Y",
  },
  {
    "bbox": {
      "height": 15,
      "width": 87.95159999999998,
      "x": 504,
      "y": 561.1483999999999,
    },
    "text": "   is to act ",
  },
  {
    "bbox": {
      "height": 15,
      "width": 360.756,
      "x": 36,
      "y": 540.1483999999999,
    },
    "text": "as my Intermediary in respect of the Import One Stop Shop (IOSS). ",
  },
  {
    "bbox": {
      "height": 15,
      "width": 520.1159999999995,
      "x": 36,
      "y": 494.4043999999999,
    },
    "text": "This arrangement will remain in place unless the supplier or intermediary is excluded from ",
  },
  {
    "bbox": {
      "height": 15,
      "width": 512.0759999999996,
      "x": 36,
      "y": 480.0043999999999,
    },
    "text": "use of the scheme or until the Revenue Commissioners are notified of a change by either ",
  },
  {
    "bbox": {
      "height": 15,
      "width": 149.30400000000003,
      "x": 36,
      "y": 465.60439999999994,
    },
    "text": "the Intermediary or Client.",
  },
  {
    "bbox": {
      "height": 15,
      "width": 37.956,
      "x": 36,
      "y": 428.0259,
    },
    "text": "Signed",
  },
  {
    "bbox": {
      "height": 15,
      "width": 201.45240000000007,
      "x": 293.532,
      "y": 428.0259,
    },
    "text": "Date        D    D      M    M       Y     Y    Y     Y",
  },
  {
    "bbox": {
      "height": 15,
      "width": 73.95600000000002,
      "x": 136.07999999999998,
      "y": 413.6259,
    },
    "text": "Intermediary  ",
  },
  {
    "bbox": {
      "height": 15,
