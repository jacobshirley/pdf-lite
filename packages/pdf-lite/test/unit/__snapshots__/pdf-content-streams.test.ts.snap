      },
      {
        "h": 13.75,
        "text": "Part A2 – Owners information",
        "w": 155.2,
        "x": 27,
        "y": 429.2,
      },
      {
        "h": 12.5,
        "text": "Enter information for the sole proprietor, or all partners, corporation directors, or officers of the business. If you need more ",
        "w": 540.73,
        "x": 27,
        "y": 412.72,
      },
      {
        "h": 12.5,
        "text": "space, include the information on a separate piece of paper. The social insurance number (SIN) is ",
        "w": 436.25,
        "x": 27,
        "y": 400.72,
      },
      {
        "h": 12.5,
        "text": "mandatory",
        "w": 51.62,
        "x": 462.75,
        "y": 400.72,
      },
      {
        "h": 12.5,
        "text": " for the sole ",
        "w": 55.53,
        "x": 513.87,
        "y": 400.72,
      },
      {
        "h": 12.5,
        "text": "proprietor applying to register for a GST/HST program account (Social Insurance Number Disclosure Regulations, Excise Tax ",
        "w": 557.91,
        "x": 27,
        "y": 388.72,
      },
      {
