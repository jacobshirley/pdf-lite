        "x": 36,
        "y": 682.72,
      },
      {
        "h": 12.5,
        "text": "•",
        "w": 4,
        "x": 28.25,
        "y": 670.28,
      },
      {
        "h": 12.5,
        "text": "trust account",
        "w": 57.75,
        "x": 36,
        "y": 670.72,
      },
      {
        "h": 12.5,
        "text": "•",
        "w": 4,
        "x": 28.25,
        "y": 658.28,
      },
      {
        "h": 12.5,
