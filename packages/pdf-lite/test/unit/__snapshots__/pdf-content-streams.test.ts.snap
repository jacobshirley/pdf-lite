        "text": "Fill in a separate RC1 form for each division of your business that requires a payroll deductions program account.",
        "w": 500.7,
        "x": 27,
        "y": 697.75,
      },
      {
        "h": 13.75,
        "text": "Part C1 – Payroll deductions program account identification",
        "w": 314.13,
        "x": 27,
        "y": 670.7,
      },
      {
        "h": 12.5,
        "text": "If the information is the same as in Part A3, tick this box.",
        "w": 249.5,
        "x": 27,
        "y": 649.4,
      },
      {
        "h": 12.5,
        "text": "If you want to use a separate name for this program account, enter the name. For example, a section or a division name.",
        "w": 533.53,
        "x": 27,
        "y": 627.65,
      },
      {
        "h": 12.5,
        "text": "Email address (for information on how we will use your email address, see page 1)",
        "w": 365.63,
        "x": 27,
        "y": 597.65,
      },
      {
        "h": 12.5,
        "text": "Physical business location",
        "w": 117.21,
        "x": 27,
        "y": 567.66,
      },
      {
        "h": 12.5,
        "text": "City",
        "w": 17.72,
        "x": 411,
        "y": 567.66,
      },
      {
        "h": 12.5,
        "text": "Province, territory, or state",
        "w": 117.76,
        "x": 27,
        "y": 537.66,
