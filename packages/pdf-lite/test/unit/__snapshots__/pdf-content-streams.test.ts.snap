      },
      {
        "h": 13.75,
        "text": "Part B2 – Filing information",
        "w": 144.19,
        "x": 27,
        "y": 710.19,
      },
      {
        "h": 12.5,
        "text": "Enter the total annual revenue from your",
        "w": 175.89,
        "x": 27,
        "y": 690.21,
      },
      {
        "h": 12.5,
        "text": " taxable supplies in Canada",
        "w": 129.03,
        "x": 202.4,
        "y": 690.21,
      },
      {
        "h": 12.5,
        "text": " (dollar amount only — if you have no revenues, enter "0").",
        "w": 254.74,
        "x": 330.94,
        "y": 690.21,
      },
      {
        "h": 12.5,
        "text": "$",
        "w": 6.06,
        "x": 36,
        "y": 670.8,
      },
      {
        "h": 12.5,
        "text": "Enter the total annual revenue from your",
        "w": 175.89,
        "x": 27,
        "y": 651.21,
      },
      {
        "h": 12.5,
        "text": " worldwide taxable supplies",
        "w": 130.11,
        "x": 202.4,
        "y": 651.21,
      },
      {
        "h": 12.5,
        "text": " (dollar amount only — if you have no revenues, enter "0").",
        "w": 254.74,
        "x": 332.03,
        "y": 651.21,
      },
      {
        "h": 12.5,
        "text": "$",
        "w": 6.06,
        "x": 36,
        "y": 631.8,
      },
      {
        "h": 12.5,
        "text": "Enter the fiscal year-end for GST/HST purposes. If you do not enter a date, we will enter December 31.",
        "w": 456.26,
        "x": 27,
        "y": 612.25,
      },
      {
        "h": 12.5,
        "text": "Date (MMDD)",
        "w": 62.16,
        "x": 36,
        "y": 592.16,
      },
      {
        "h": 12.5,
        "text": "Do you want to make an election to change the fiscal year-end for GST/HST purposes?",
        "w": 386.79,
        "x": 27,
        "y": 573.24,
      },
      {
        "h": 12.5,
        "text": "Yes",
        "w": 17.73,
        "x": 54.01,
        "y": 552.65,
      },
      {
        "h": 12.5,
        "text": "No",
        "w": 13.28,
        "x": 111,
        "y": 552.65,
      },
      {
        "h": 12.5,
        "text": "If",
        "w": 6.06,
        "x": 36,
        "y": 534.26,
      },
      {
        "h": 12.5,
        "text": "yes",
        "w": 17.18,
        "x": 44.34,
        "y": 534.26,
      },
      {
        "h": 12.5,
        "text": ", enter the date you would like to use.",
        "w": 166.15,
        "x": 61.02,
        "y": 534.26,
      },
      {
        "h": 12.5,
        "text": "Date (MMDD)",
        "w": 62.16,
        "x": 36,
        "y": 514.15,
      },
      {
        "h": 12.5,
        "text": "Enter theeffective date of registration for GST/HST purposes.",
        "w": 293.34,
        "x": 27,
        "y": 492.35,
      },
      {
        "h": 12.5,
        "text": "Date (YYYYMMDD)",
        "w": 88.84,
        "x": 36,
        "y": 475.4,
      },
      {
        "h": 13.75,
        "text": "Part B3 – Reporting period",
        "w": 139.91,
        "x": 27,
        "y": 446.18,
      },
      {
        "h": 12.5,
        "text": "Unless you are a charity or a listed financial institution",
        "w": 238.37,
        "x": 27,
        "y": 425.7,
      },
      {
        "h": 12.5,
        "text": "*",
        "w": 4.39,
        "x": 264.87,
        "y": 425.7,
      },
      {
        "h": 12.5,
        "text": " (other than a deemed listed financial institution), we will assign you a ",
        "w": 309.52,
        "x": 268.76,
        "y": 425.7,
      },
      {
        "h": 12.5,
        "text": "reporting period based on your total annual revenues from GST/HST taxable supplies made in Canada (including those of ",
        "w": 541.31,
        "x": 27,
        "y": 413.7,
      },
      {
        "h": 12.5,
        "text": "your associates) for the ",
        "w": 107.21,
        "x": 27,
        "y": 401.7,
      },
      {
        "h": 12.5,
        "text": "preceding year",
        "w": 71.64,
        "x": 133.71,
        "y": 401.7,
      },
      {
        "h": 12.5,
        "text": ". Tick the box in the left column that applies to you. If you want to elect to have a ",
        "w": 357.92,
        "x": 204.85,
        "y": 401.7,
      },
      {
        "h": 12.5,
        "text": "different reporting period than the one that would be assigned to you, your options are listed below. Tick the box in the right ",
        "w": 546.9,
        "x": 27,
        "y": 389.7,
      },
      {
        "h": 12.5,
        "text": "column that applies to you.",
        "w": 119.45,
        "x": 27,
        "y": 377.7,
      },
      {
        "h": 12.5,
        "text": "Reporting period election",
        "w": 121.63,
        "x": 27,
        "y": 360.27,
      },
      {
        "h": 12.5,
        "text": "Tick",
        "w": 18.83,
        "x": 27,
        "y": 342.4,
      },
      {
        "h": 12.5,
        "text": " yes",
        "w": 19.96,
        "x": 45.33,
        "y": 342.4,
      },
      {
        "h": 12.5,
        "text": " if you want to file more frequently than the reporting period that would be assigned to you.",
        "w": 399.6,
        "x": 64.79,
        "y": 342.4,
      },
      {
        "h": 12.5,
        "text": "Yes",
        "w": 17.73,
        "x": 54.01,
        "y": 321.65,
      },
      {
        "h": 12.5,
        "text": "No",
        "w": 13.28,
        "x": 111,
        "y": 321.65,
      },
      {
        "h": 12.5,
        "text": "Total annual revenue from ",
        "w": 128.31,
        "x": 52.99,
        "y": 289.35,
      },
      {
        "h": 12.5,
        "text": "taxable supplies in Canada",
        "w": 128.88,
        "x": 51.31,
        "y": 277.35,
      },
      {
        "h": 12.5,
        "text": "(including those of your associates)",
        "w": 171.65,
        "x": 29.92,
        "y": 265.35,
      },
      {
